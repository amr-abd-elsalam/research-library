# ─────────────────────────────────────────────────────────────────
# .env.example
# نموذج لمتغيرات البيئة — آمن للـ git — انسخه إلى .env وعدّله
# ─────────────────────────────────────────────────────────────────
#
# طريقة الاستخدام:
#   cp .env.example .env
#   ثم عدّل القيم في .env
#
# ⚠️  لا ترفع .env لـ git أبداً — فقط .env.example
# ─────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════
# Gemini API
# ══════════════════════════════════════════════════════════════════

# مفتاح Gemini API — مطلوب للـ Backend والـ Pipeline
# احصل عليه من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ══════════════════════════════════════════════════════════════════
# Qdrant — Vector Database
# ══════════════════════════════════════════════════════════════════

# عنوان خادم Qdrant المحلي
QDRANT_URL=http://localhost:6333

# اسم الـ collection في Qdrant
QDRANT_COLLECTION=knowledge


# ══════════════════════════════════════════════════════════════════
# Node.js Server
# ══════════════════════════════════════════════════════════════════

# المنفذ الذي يستمع عليه الـ server
PORT=3000

# بيئة التشغيل
NODE_ENV=production

# الـ Origin المسموح بها لـ CORS
ALLOWED_ORIGIN=
