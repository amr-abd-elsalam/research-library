# ─────────────────────────────────────────────────────────────────
# .env.example
# نموذج لمتغيرات البيئة — آمن للـ git — انسخه إلى .env وعدّله
# ─────────────────────────────────────────────────────────────────
#
# طريقة الاستخدام:
#   cp .env.example .env
#   ثم عدّل القيم في .env
#
# ⚠️  لا ترفع .env لـ git أبداً — فقط .env.example
# ─────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════
# Gemini API
# ══════════════════════════════════════════════════════════════════

# مفتاح Gemini API — مطلوب للـ Backend والـ Pipeline
# احصل عليه من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ══════════════════════════════════════════════════════════════════
# Qdrant — Vector Database
# ══════════════════════════════════════════════════════════════════

# عنوان خادم Qdrant المحلي
QDRANT_URL=http://localhost:6333

# اسم الـ collection في Qdrant
QDRANT_COLLECTION=knowledge


# ══════════════════════════════════════════════════════════════════
# Node.js Server
# ══════════════════════════════════════════════════════════════════

# المنفذ الذي يستمع عليه الـ server
PORT=3000

# بيئة التشغيل
NODE_ENV=production

# الـ Origin المسموح بها لـ CORS
ALLOWED_ORIGIN=

# ══════════════════════════════════════════════════════════════════
# Admin
# ══════════════════════════════════════════════════════════════════

# توكن الأدمن — مطلوب للوصول لـ /api/admin/*
# ولّد واحد عشوائي: node -e "console.log(crypto.randomUUID())"
ADMIN_TOKEN=836aa9cc-1449-462f-9047-7a5e5894cd93

# ══════════════════════════════════════════════════════════════════
# Access Control — التحكم في الوصول
# ══════════════════════════════════════════════════════════════════

# وضع الوصول: public | pin | token
#   public — أي حد يدخل (الافتراضي)
#   pin    — المستخدم يدخل رمز PIN قبل الاستخدام
#   token  — الرابط لازم يكون فيه ?token=xxx
ACCESS_MODE=public

# رمز PIN — مطلوب إذا ACCESS_MODE=pin
# أرقام فقط، 4-8 خانات
ACCESS_PIN=

# توكنات الوصول — مطلوب إذا ACCESS_MODE=token
# قائمة مفصولة بفواصل: token1,token2,token3
ACCESS_TOKENS=

# ══════════════════════════════════════════════════════════════════
# Sessions — Server-Side Chat History
# ══════════════════════════════════════════════════════════════════

# كل كم ساعة يتم تنظيف الجلسات المنتهية
# القيمة الافتراضية: 24 ساعة
SESSIONS_CLEANUP_HOURS=24
